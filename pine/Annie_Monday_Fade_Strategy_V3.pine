//@version=6
// =============================================================================
// Annie Monday Fade — Strategy V3  ·  STREAMING
// -----------------------------------------------------------------------------
// strategy() twin of "Annie Monday Fade — V3 STREAMING" so TradingView's Strategy
// Tester shows every trade: entry/exit arrows, trade list, P&L. The SIGNAL LOGIC
// is IDENTICAL to the indicator (and to backtests/g1_pine_mirror_v3.py, which
// matches the 167-trade streaming ground truth 159/167 = 95.2% exact).
//
// V3 = the live-executable streaming rebuild: it commits to the RUNNING early-week
// extreme in real time and fires AT the entry bar — no lock-at-close, no repaint.
// Honest, live-executable in-sample economics (2019-09→2024-12, Monday fade):
//   167 trades · +0.347R/trade @ 2.5R · WR 45.5% · PF 1.64 · t=2.84 · ~2.7/mo.
//   (@1.9R: +0.257R, t=2.46, PF 1.51.) The old +0.382R was hindsight-mode.
//
// HOW FILLS WORK IN THE TESTER (read before judging its P&L): the streaming entry
// is the OPEN of the bar after the retest. This strategy submits a market order the
// moment that entry bar confirms, so the Tester fills it on the FOLLOWING open —
// about one 15m bar later than the engine's fill. Stop/TP LEVELS use the engine
// geometry (stop = running weekly extreme ±0.05%, TP a fixed R multiple from the
// engine entry). So the picture on the chart is the validated trade plan; only the
// delayed-fill P&L differs from the authoritative backtest reports on the site.
// TradingView also caps 15m history (~20k bars) so you see recent months, not the
// whole 2019-2024 record. The Tester is for SEEING the trades; the numbers of
// record are the streaming backtest.
//
// TP is an INPUT (default 2.5R, selectable 1.9 / 2.5 / 3.0). PVSRA 200%-class
// vector: volume ≥ 2.0× ta.sma(volume[1],10). Chart: BTCUSDT perp, 15m.
//
// V3.2 FULLY-CAUSAL DISPLAY (2026-07-20, Igor's order — signals UNCHANGED, same
// layer as the indicator): every mark prints AT the confirmed bar the machine
// learned it — throttled gray "peak?" trail at commit bars, yellow L1 box at the
// L1 bar, blue retest tag at the retest bar, entry label (peak price in text) at
// the entry bar, lines projected forward only. Nothing retro-positioned, nothing
// moved or deleted. Plus the status panel and the "peak committed" alert.
// =============================================================================

strategy("Annie Monday Fade — Strategy V3", overlay = true,
     initial_capital = 100000, currency = currency.USD,
     commission_type = strategy.commission.percent, commission_value = 0.05,
     slippage = 2, max_lines_count = 500, max_labels_count = 500, max_boxes_count = 500)

// ----------------------------- Inputs ----------------------------------------
gA = "Anchors (Igor's weekly model)"
i_tz       = input.string("America/New_York", "Anchor timezone", group = gA)
i_openHour = input.int(17, "Week open hour (Sunday, NY)", minval = 0, maxval = 23, group = gA)
i_friHour  = input.int(8,  "Friday hard-cutoff hour (NY)", minval = 0, maxval = 23, group = gA)
i_earlyFrac= input.float(0.286, "Early-window fraction of week (Sun/Mon/Tue)", minval = 0.1, maxval = 0.6, step = 0.001, group = gA)

gD = "Detector knobs (validated defaults — do not change to trade the edge)"
i_emaLen   = input.int(50, "50-EMA length", minval = 2, group = gD)
i_volLb    = input.int(10, "PVSRA volume lookback (prior N)", minval = 2, group = gD)
i_vecMult  = input.float(2.0, "200%-class vector threshold (x vol avg)", minval = 1.0, step = 0.1, group = gD)
i_minSpike = input.float(0.10, "Min spike beyond box (%)", minval = 0.0, step = 0.01, group = gD)
i_touchTol = input.float(0.15, "50-EMA wick-touch tolerance (%)", minval = 0.0, step = 0.01, group = gD)
i_crossTol = input.float(0.10, "50-EMA body-cross tolerance (%)", minval = 0.0, step = 0.01, group = gD)
i_span     = input.int(320, "Max bars L1 -> retest", minval = 1, group = gD)
i_stopBuf  = input.float(0.05, "Stop buffer beyond extreme (%)", minval = 0.0, step = 0.01, group = gD)
i_rr       = input.float(2.5, "TP (R multiple)", options = [1.9, 2.5, 3.0], group = gD)
i_mondayOnly = input.bool(true, "Monday-spike only (the validated edge)", group = gD)

gR = "Strategy sizing"
i_riskPct  = input.float(1.0, "Risk per trade (% of equity)", minval = 0.01, maxval = 10.0, step = 0.1, group = gR)

gV = "Visuals"
i_showBox    = input.bool(true,  "Weekend box", group = gV)
i_showL1     = input.bool(true,  "L1 vector highlight", group = gV)
i_showRetest = input.bool(true,  "Retest marker", group = gV)
i_showEntry  = input.bool(true,  "Entry arrow", group = gV)
i_showStopTP = input.bool(true,  "Stop / TP lines", group = gV)
i_showExt    = input.bool(true,  "Weekly-extreme line", group = gV)
i_showEma    = input.bool(true,  "50-EMA", group = gV)
i_showLivePeak = input.bool(true, "Live peak-commit trail (gray, causal)", group = gV)
i_trailThrottle = input.float(0.25, "Trail re-label threshold (% move of extreme)", minval = 0.0, step = 0.05, group = gV)
i_showState  = input.bool(true,  "Status panel (top-right)", group = gV)

// derived tolerances (fractions)
touchTol = i_touchTol / 100.0
crossTol = i_crossTol / 100.0
minSpike = i_minSpike / 100.0
stopBuf  = i_stopBuf  / 100.0

DAY_MS = 86400000

// ----------------------------- Per-bar indicators ----------------------------
ema50 = ta.ema(close, i_emaLen)
avgVol   = ta.sma(volume[1], i_volLb)
volRatio = na(avgVol) or avgVol == 0 ? 0.0 : volume / avgVol
is200    = volRatio >= i_vecMult
isUp     = close >= open

plot(i_showEma ? ema50 : na, "50 EMA", color = color.new(color.orange, 0), linewidth = 1)

// ----------------------------- Week time anchors -----------------------------
_dow  = dayofweek(time, i_tz)
_yr   = year(time, i_tz)
_mo   = month(time, i_tz)
_dy   = dayofmonth(time, i_tz)
_today0     = timestamp(i_tz, _yr, _mo, _dy, i_openHour, 0)
_daysBack   = _dow - 1
_approxSun  = _today0 - _daysBack * DAY_MS
weekOpenTs  = timestamp(i_tz, year(_approxSun, i_tz), month(_approxSun, i_tz), dayofmonth(_approxSun, i_tz), i_openHour, 0)
if time < weekOpenTs
    _approxSun2 = _today0 - (_daysBack + 7) * DAY_MS
    weekOpenTs := timestamp(i_tz, year(_approxSun2, i_tz), month(_approxSun2, i_tz), dayofmonth(_approxSun2, i_tz), i_openHour, 0)

weekEndTs  = weekOpenTs + 7 * DAY_MS
earlyEndTs = weekOpenTs + int(i_earlyFrac * 7.0 * DAY_MS)
_friApprox = weekOpenTs + 5 * DAY_MS
friEndTs   = timestamp(i_tz, year(_friApprox, i_tz), month(_friApprox, i_tz), dayofmonth(_friApprox, i_tz), i_friHour, 0)

newWeek = weekOpenTs != weekOpenTs[1]

// ----------------------------- Persistent streaming state --------------------
var float boxTop  = na
var float boxBot  = na
var float pendTop = na
var float pendBot = na

var float weekHigh = na
var float weekLow  = na
var float earlyHigh = na
var float earlyLow  = na
var int   earlyHiT  = 0
var int   earlyLoT  = 0

var int   fadeDir   = 0
var float extPrice  = na
var int   extBar    = 0
var int   extT      = 0
var bool  committed = false
var bool  chainDead = false
var bool  entryTaken= false

var bool  l1Found   = false
var int   l1Bar     = 0
var int   l1T       = 0
var float l1Low     = na
var float l1High    = na
var bool  c2latch   = false

var bool  armed        = false
var float armWick      = na
var int   armFadeDir   = 0
var int   armExtT      = 0
var float armExtPrice  = na
var int   armL1T       = 0
var float armL1H       = na
var float armL1L       = na
var int   armRetestT   = 0
var float armRetestEma = na

longFired  = false
shortFired = false
peakCommitted = false            // true on the bar a LABELED peak commit prints (throttled)
oStopP = 0.0
oTpP   = 0.0
oSd    = 0.0

// trail throttle state (display only — never read by signal logic)
var float lastLblP   = na
var int   lastLblDir = 0

if barstate.isconfirmed
    // --- New week bootstrap ---
    if newWeek
        boxTop := pendTop
        boxBot := pendBot
        pendTop := na
        pendBot := na
        weekHigh := na
        weekLow  := na
        earlyHigh := na
        earlyLow  := na
        earlyHiT := 0
        earlyLoT := 0
        fadeDir   := 0
        extPrice  := na
        extT      := 0
        extBar    := 0
        committed := false
        chainDead := false
        entryTaken:= false
        l1Found   := false
        l1Bar     := 0
        c2latch   := false
        armed     := false
        lastLblP  := na
        lastLblDir:= 0
        if i_showBox and not na(boxTop) and not na(boxBot)
            box.new(weekOpenTs - 2 * DAY_MS, boxTop, weekOpenTs, boxBot, xloc = xloc.bar_time,
                 border_color = color.new(color.gray, 40), bgcolor = color.new(color.gray, 90))

    // --- running weekly extreme (stop), every bar ---
    weekHigh := na(weekHigh) ? high : math.max(weekHigh, high)
    weekLow  := na(weekLow)  ? low  : math.min(weekLow, low)

    // --- weekend box accumulation for the FOLLOWING week ---
    if time >= weekOpenTs + 5 * DAY_MS and time < weekEndTs
        pendTop := na(pendTop) ? close : math.max(pendTop, close)
        pendBot := na(pendBot) ? close : math.min(pendBot, close)

    // (1) ARMED-ENTRY resolution: retest completed last bar -> this bar's open fills
    if armed and not entryTaken
        entryRef = open
        if time < friEndTs
            wickOk = armFadeDir == -1 ? armWick > entryRef : armWick < entryRef
            if wickOk
                entryTaken := true
                extHr = hour(armExtT, i_tz)
                extDw = dayofweek(armExtT, i_tz)
                isMon = (extHr < i_openHour and extDw == 2) or (extHr >= i_openHour and extDw == 1)
                if (not i_mondayOnly) or isMon
                    stopP = armFadeDir == -1 ? armWick * (1 + stopBuf) : armWick * (1 - stopBuf)
                    sd    = math.abs(entryRef - stopP)
                    if sd > 0
                        tpP = armFadeDir == -1 ? entryRef - i_rr * sd : entryRef + i_rr * sd
                        oStopP := stopP
                        oTpP   := tpP
                        oSd    := sd
                        if armFadeDir == 1
                            longFired := true
                        else
                            shortFired := true
                        dirCol = armFadeDir == -1 ? color.red : color.green
                        // ---- causal entry drawing: everything at THIS bar or
                        //      projected forward; nothing positioned at past bars ----
                        if i_showEntry
                            label.new(time, entryRef,
                                 text = (armFadeDir == -1 ? "SHORT (engine bar" : "LONG (engine bar") + ", peak " + str.tostring(armExtPrice, format.mintick) + ")",
                                 xloc = xloc.bar_time, style = armFadeDir == -1 ? label.style_label_down : label.style_label_up,
                                 color = color.new(dirCol, 0), textcolor = color.white, size = size.small)
                        if i_showExt
                            line.new(time, armWick, friEndTs, armWick, xloc = xloc.bar_time,
                                 color = color.new(color.gray, 20), width = 1, style = line.style_dotted)
                        if i_showStopTP
                            line.new(time, stopP, friEndTs, stopP, xloc = xloc.bar_time,
                                 color = color.new(color.red, 0), width = 1, style = line.style_dashed)
                            line.new(time, tpP, friEndTs, tpP, xloc = xloc.bar_time,
                                 color = color.new(color.green, 0), width = 1, style = line.style_dashed)
                            label.new(friEndTs, stopP, "stop", xloc = xloc.bar_time, style = label.style_label_left,
                                 color = color.new(color.red, 30), textcolor = color.white, size = size.tiny)
                            label.new(friEndTs, tpP, str.tostring(i_rr, "#.#") + "R TP", xloc = xloc.bar_time,
                                 style = label.style_label_left, color = color.new(color.green, 30),
                                 textcolor = color.white, size = size.tiny)
            else
                chainDead := true
        else
            chainDead := true
        armed := false

    // (2) EARLY-WINDOW running spike extreme + STREAMING commit
    if not entryTaken and time <= earlyEndTs
        newExtreme = false
        if na(earlyHigh) or high > earlyHigh
            earlyHigh := high
            earlyHiT  := time
            newExtreme := true
        if na(earlyLow) or low < earlyLow
            earlyLow := low
            earlyLoT := time
            newExtreme := true
        boxOk = not na(boxTop) and not na(boxBot) and boxTop > boxBot
        if newExtreme and boxOk
            upExc   = (earlyHigh - boxTop) / boxTop
            downExc = (boxBot - earlyLow) / boxBot
            if math.max(upExc, downExc) >= minSpike
                newDir  = upExc >= downExc ? -1 : 1
                newExtT = newDir == -1 ? earlyHiT : earlyLoT
                newExtP = newDir == -1 ? earlyHigh : earlyLow
                if newDir != fadeDir or newExtT != extT
                    fadeDir   := newDir
                    extT      := newExtT
                    extBar    := bar_index
                    extPrice  := newExtP
                    committed := true
                    chainDead := false
                    l1Found   := false
                    c2latch   := false
                    // throttled causal peak trail (display only; commits never throttled)
                    doLbl = na(lastLblP) or fadeDir != lastLblDir or
                         math.abs(extPrice - lastLblP) / lastLblP >= i_trailThrottle / 100.0
                    if doLbl
                        peakCommitted := true
                        lastLblP   := extPrice
                        lastLblDir := fadeDir
                        if i_showLivePeak
                            label.new(time, extPrice, text = fadeDir == -1 ? "▲ peak?" : "▼ peak?",
                                 xloc = xloc.bar_time,
                                 style = fadeDir == -1 ? label.style_label_down : label.style_label_up,
                                 color = color.new(color.gray, 55), textcolor = color.white, size = size.tiny)

    // (3) CHAIN step: L1 -> retest -> ARM (forward only)
    if committed and not chainDead and not armed and not entryTaken and bar_index >= extBar
        emaOk = not na(ema50) and ema50 != 0
        if not l1Found
            brk = false
            if emaOk and is200
                if fadeDir == 1 and isUp and close >= ema50 and open <= ema50 * (1 + crossTol)
                    brk := true
                if fadeDir == -1 and not isUp and close <= ema50 and open >= ema50 * (1 - crossTol)
                    brk := true
            if brk
                l1Found := true
                l1Bar   := bar_index
                l1T     := time
                l1Low   := low
                l1High  := high
                c2latch := false
                // causal L1 mark: printed AT the L1 bar the moment it qualifies
                if i_showL1
                    box.new(time, high, time + 15 * 60000, low, xloc = xloc.bar_time,
                         border_color = color.new(color.yellow, 0), bgcolor = color.new(color.yellow, 80))
                    label.new(time, low, text = "L1", xloc = xloc.bar_time,
                         style = label.style_label_up, color = color.new(color.yellow, 40),
                         textcolor = color.black, size = size.tiny)
        else if bar_index > l1Bar
            if bar_index >= l1Bar + i_span
                chainDead := true
            else if emaOk
                if fadeDir == 1 and close < ema50 * (1 - crossTol)
                    chainDead := true
                else if fadeDir == -1 and close > ema50 * (1 + crossTol)
                    chainDead := true
                else
                    if high >= l1Low and low <= l1High
                        c2latch := true
                    touched = fadeDir == 1 ? low <= ema50 * (1 + touchTol) : high >= ema50 * (1 - touchTol)
                    bodyOk  = fadeDir == 1 ? math.min(open, close) >= ema50 * (1 - crossTol) : math.max(open, close) <= ema50 * (1 + crossTol)
                    if touched and bodyOk and c2latch
                        armed        := true
                        armFadeDir   := fadeDir
                        armWick      := fadeDir == -1 ? weekHigh : weekLow
                        armExtT      := extT
                        armExtPrice  := extPrice
                        armL1T       := l1T
                        armL1H       := l1High
                        armL1L       := l1Low
                        armRetestT   := time
                        armRetestEma := ema50
                        // causal retest mark: printed AT the retest bar, now
                        if i_showRetest
                            label.new(time, ema50, text = "retest", xloc = xloc.bar_time,
                                 style = label.style_label_center, color = color.new(color.blue, 30),
                                 textcolor = color.white, size = size.tiny)

    // --- STRATEGY ORDERS (market submitted at the engine entry bar; risk-sized) ---
    if (longFired or shortFired) and oSd > 0
        qty = strategy.equity * i_riskPct / 100.0 / oSd
        if qty > 0
            isLong = longFired
            strategy.entry("fade", isLong ? strategy.long : strategy.short, qty = qty,
                 comment = isLong ? "fade LONG" : "fade SHORT")
            strategy.exit("exit", "fade", stop = oStopP, limit = oTpP)

    // --- Friday hard cap: flat before the weekend, always ---
    if strategy.position_size != 0 and time >= friEndTs
        strategy.close("fade", comment = "friday cap")

entryFired = longFired or shortFired

// ----------------------------- Alerts ----------------------------------------
alertcondition(longFired, title = "Annie Monday Fade V3 — LONG entry",
     message = "Annie Monday Fade V3 Strategy: LONG entry on BTCUSDT 15m at {{time}}")
alertcondition(shortFired, title = "Annie Monday Fade V3 — SHORT entry",
     message = "Annie Monday Fade V3 Strategy: SHORT entry on BTCUSDT 15m at {{time}}")
alertcondition(peakCommitted, title = "Annie Monday Fade V3 — peak committed (streaming)",
     message = "Annie Monday Fade V3 Strategy: machine committed a running peak on BTCUSDT 15m at {{time}} — now hunting L1 vector + retest. NOTE: a newer extreme can re-commit (streaming); entry alert is the trade signal.")

plotshape(longFired,  title = "LONG entry (signal bar)",  style = shape.triangleup,   location = location.belowbar, color = color.new(color.green, 0), size = size.tiny)
plotshape(shortFired, title = "SHORT entry (signal bar)", style = shape.triangledown, location = location.abovebar, color = color.new(color.red, 0),   size = size.tiny)

// ----------------------------- Status panel -----------------------------------
// HUD of the LAST-CONFIRMED machine state. State vars mutate only inside
// barstate.isconfirmed, so intrabar ticks cannot change what this shows — the
// panel is a read-out, not a bar-anchored drawing: zero history mutation.
var table st = table.new(position.top_right, 2, 6,
     bgcolor = color.new(color.black, 15), border_width = 1,
     border_color = color.new(color.gray, 60), frame_width = 1,
     frame_color = color.new(color.gray, 40))

if i_showState and barstate.islast
    boxOkS  = not na(boxTop) and not na(boxBot) and boxTop > boxBot
    phase = "waiting spike out of box"
    if entryTaken
        phase := "ENTERED — week decided"
    else if armed
        phase := "ARMED — fills next 15m open"
    else if committed and not chainDead and l1Found
        phase := "L1 ✓ — hunting retest"
    else if committed and not chainDead
        phase := "peak ✓ — waiting L1 vector"
    else if committed and chainDead and time <= earlyEndTs
        phase := "chain dead — waiting new extreme"
    else if time > earlyEndTs
        phase := committed ? "chain dead — window closed" : "no spike — window closed"
    sideTxt = fadeDir == -1 ? "SHORT (fade spike-high)" : fadeDir == 1 ? "LONG (fade spike-low)" : "—"
    peakTxt = committed ? str.tostring(extPrice, format.mintick) : "—"
    monTxt  = "—"
    if committed
        _eh = hour(extT, i_tz)
        _ed = dayofweek(extT, i_tz)
        _isMon = (_eh < i_openHour and _ed == 2) or (_eh >= i_openHour and _ed == 1)
        monTxt := _isMon ? "Mon ✓ (tradeable)" : i_mondayOnly ? "not Mon → gate blocks entry" : "not Mon (gate off)"
    winTxt = time <= earlyEndTs ? "OPEN (to Tue 17:00 NY)" : "closed"
    boxTxt = boxOkS ? str.tostring(boxBot, format.mintick) + " – " + str.tostring(boxTop, format.mintick) : "no box (need Fri–Sun closes)"
    _hd = color.new(color.silver, 20)
    _tx = color.white
    table.cell(st, 0, 0, "V3 state",      text_color = _hd, text_size = size.small, text_halign = text.align_left)
    table.cell(st, 1, 0, phase,           text_color = _tx, text_size = size.small, text_halign = text.align_left)
    table.cell(st, 0, 1, "side",          text_color = _hd, text_size = size.small, text_halign = text.align_left)
    table.cell(st, 1, 1, sideTxt,         text_color = _tx, text_size = size.small, text_halign = text.align_left)
    table.cell(st, 0, 2, "peak",          text_color = _hd, text_size = size.small, text_halign = text.align_left)
    table.cell(st, 1, 2, peakTxt,         text_color = _tx, text_size = size.small, text_halign = text.align_left)
    table.cell(st, 0, 3, "Monday gate",   text_color = _hd, text_size = size.small, text_halign = text.align_left)
    table.cell(st, 1, 3, monTxt,          text_color = _tx, text_size = size.small, text_halign = text.align_left)
    table.cell(st, 0, 4, "early window",  text_color = _hd, text_size = size.small, text_halign = text.align_left)
    table.cell(st, 1, 4, winTxt,          text_color = _tx, text_size = size.small, text_halign = text.align_left)
    table.cell(st, 0, 5, "weekend box",   text_color = _hd, text_size = size.small, text_halign = text.align_left)
    table.cell(st, 1, 5, boxTxt,          text_color = _tx, text_size = size.small, text_halign = text.align_left)
